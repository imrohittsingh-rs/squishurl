<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head', { title: 'Sign Up - SquishUrl' }) %>
</head>

<body>
  <%- include('partials/nav') %>

    <div class="container my-5">
      <div class="row justify-content-center">
        <div class="col-md-5">
          <div class="card p-4 shadow">
            <h2 class="card-title text-center mb-4 fw-bold text-primary">Sign Up</h2>

            <% if (locals.error) { %>
              <div class="alert alert-danger text-center py-2" role="alert">
                <%= error %>
              </div>
              <% } %>

                <form action="/user" method="post" class="needs-validation">
                  <div class="mb-3">
                    <label for="name" class="form-label text-secondary">Full Name</label>
                    <input type="text" class="form-control bg-dark text-light border-secondary" id="name" name="name"
                      placeholder="John Doe" required>
                  </div>

                  <div class="mb-3">
                    <label for="email" class="form-label text-secondary">Email Address</label>
                    <input type="email" class="form-control bg-dark text-light border-secondary" id="email" name="email"
                      placeholder="name@example.com" required>
                  </div>

                  <div class="mb-4">
                    <label for="password" class="form-label text-secondary">Password (min 8 characters)</label>
                    <input type="password" class="form-control bg-dark text-light border-secondary" id="password"
                      name="password" minlength="8" placeholder="Create a strong password" required>
                  </div>

                  <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary btn-lg fw-semibold">Sign Up</button>
                  </div>
                </form>

                <div class="text-center mt-3 text-secondary">
                  Already have an account? <a href="/login" class="text-info text-decoration-none">Login</a>
                </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/script') %>
</body>

</html>