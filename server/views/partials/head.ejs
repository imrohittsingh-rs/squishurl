<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>
  <%= locals.title || 'SquishUrl - URL Shortener' %>
</title>
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
  integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<!-- Google Fonts: Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<!-- Font Awesome for clean check circles / icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg==" crossorigin="anonymous" referrerpolicy="no-referrer" />

<style>
  body {
    font-family: 'Inter', sans-serif;
    background-color: #fafbfc;
    color: #111111;
    min-height: 100vh;
  }

  /* Navbar styling from image */
  .navbar {
    background-color: #ffffff !important;
    border-bottom: 1px solid #f0f0f0;
    padding-top: 15px;
    padding-bottom: 15px;
  }
  
  .navbar-brand {
    color: #111111 !important;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Brand Icon styled like the S logo in image */
  .brand-icon {
    background: #111111;
    color: #ffffff;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 18px;
  }

  .nav-link {
    color: #555555 !important;
    font-weight: 500;
    font-size: 15px;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #0877FD !important;
  }

  /* Premium Cards */
  .card {
    background-color: #ffffff;
    border: 1px solid #eaeaea;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.015);
  }

  /* Buttons */
  .btn-primary {
    background-color: #0877FD;
    border-color: #0877FD;
    color: #ffffff;
    font-weight: 600;
    border-radius: 12px;
    padding: 12px 24px;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    background-color: #055ecb;
    border-color: #055ecb;
    transform: translateY(-1px);
  }

  .btn-outline-primary {
    color: #555555;
    border-color: #eaeaea;
    background-color: transparent;
    font-weight: 600;
    border-radius: 12px;
    padding: 8px 18px;
  }

  .btn-outline-primary:hover {
    background-color: #f4f9ff;
    color: #0877FD;
    border-color: #0877FD;
  }

  .btn-dark {
    background-color: #111111;
    border-color: #111111;
    color: #ffffff;
    font-weight: 600;
    border-radius: 12px;
    padding: 12px 24px;
    transition: all 0.2s ease;
  }

  .btn-dark:hover {
    background-color: #000000;
    border-color: #000000;
    transform: translateY(-1px);
  }

  /* Inputs */
  .form-control {
    background-color: #ffffff;
    color: #111111;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px 18px;
    font-size: 15px;
  }

  .form-control:focus {
    border-color: #0877FD;
    box-shadow: 0 0 0 4px rgba(8, 119, 253, 0.15);
  }

  /* Custom badge styled like BETALAUNCH code in image */
  .code-badge {
    background-color: #fee2e2;
    color: #ef4444;
    padding: 3px 8px;
    border-radius: 6px;
    font-family: monospace;
    font-weight: 600;
    font-size: 14px;
  }

  /* Feature checks from image */
  .check-icon {
    color: #ffffff;
    background-color: #111111;
    border-radius: 50%;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
  }
</style>