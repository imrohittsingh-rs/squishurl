<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('partials/head', { title: 'SquishUrl - Modern URL Shortener' }) %>
</head>

<body>
  <%
    // Helper to extract domain name for favicons
    function getDomain(urlStr) {
      try {
        const url = new URL(urlStr);
        return url.hostname;
      } catch (e) {
        return 'link';
      }
    }
  %>

  <%- include('partials/nav') %>

  <div class="container my-5">
    <!-- Hero Headline matching image theme -->
    <h1 class="display-4 fw-bold text-center mt-5 mb-2 text-dark" style="font-weight: 800; letter-spacing: -1.5px;">Shorten Your Links</h1>
    <p class="text-secondary text-center fs-5 mb-5">A simple, fast, and secure way to manage your URLs.</p>

    <div class="row justify-content-center">
      <div class="col-md-9">

        <!-- URL Shortener Input Box styled exactly like image -->
        <div class="card p-3 mb-4 shadow-sm border border-light" style="background-color: #ffffff; border-radius: 16px;">
          <% if (locals.id) { %>
            <div class="alert alert-success d-flex align-items-center justify-content-between mb-4 border-0 p-3" role="alert" style="background-color: #e0f2fe; color: #0369a1; border-radius: 12px;">
              <div>
                <strong class="me-2">Success!</strong> URL Generated:
                <a href="<%= BASE_URL %>/<%= id %>" target="_blank" class="alert-link text-decoration-underline fw-semibold" style="color: #0369a1;">
                  <%= BASE_URL %>/<%= id %>
                </a>
              </div>
              <button class="btn btn-sm btn-primary py-2 px-3 fw-bold" style="background-color: #0877FD; border-color: #0877FD; border-radius: 8px;"
                onclick="navigator.clipboard.writeText('<%= BASE_URL %>/<%= id %>'); this.innerText='Copied!'; setTimeout(() => this.innerText='Copy', 1500)">Copy</button>
            </div>
          <% } %>

          <form method="POST" action="/url" class="row g-2 align-items-center">
            <div class="col-md-9 col-sm-8 m-0">
              <input type="url" name="url"
                class="form-control form-control-lg bg-white border-0 shadow-none"
                placeholder="Enter a destination URL" required
                style="padding: 14px 20px; font-size: 16px; border-radius: 12px;">
            </div>
            <div class="col-md-3 col-sm-4 d-grid m-0">
              <button type="submit" class="btn btn-primary btn-lg fw-bold d-flex align-items-center justify-content-center gap-2" style="background-color: #0877FD; border-color: #0877FD; border-radius: 12px; font-size: 15px; padding: 14px 20px;">
                Shorten <i class="fa-solid fa-wand-magic-sparkles" style="font-size: 14px;"></i>
              </button>
            </div>
          </form>
        </div>

        <!-- Shortened Link Minimal Boxes (matching image design) -->
        <% if (locals.urls && urls.length > 0) { %>
          <h4 class="fw-bold mb-4 text-dark text-start mt-5" style="letter-spacing: -0.5px;">Your Shortened Links</h4>
          <div class="d-flex flex-column gap-3 mb-5">
            <% urls.forEach((url, index) => { %>
              <% const domain = getDomain(url.redirectUrl); %>
              <div class="card p-3 border border-light shadow-sm bg-white" style="border-radius: 16px;">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                  
                  <div class="d-flex align-items-center gap-3">
                    <!-- Circular Icon Wrapper with dynamic Favicon -->
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center border" style="width: 44px; height: 44px; flex-shrink: 0; background-color: #f8fafc !important;">
                      <img src="https://www.google.com/s2/favicons?sz=64&domain=<%= domain %>" 
                           width="20" height="20" class="rounded-circle"
                           onerror="this.src='https://www.google.com/s2/favicons?sz=64&domain=google.com'">
                    </div>
                    
                    <!-- Link Details -->
                    <div>
                      <div class="d-flex align-items-center gap-2">
                        <span class="fw-semibold text-dark fs-5" style="letter-spacing: -0.2px;">
                          <%= BASE_URL.replace(/^https?:\/\//, '') %>/<%= url.shortId %>
                        </span>
                        <!-- Copy icon overlay -->
                        <i class="fa-regular fa-copy text-secondary cursor-pointer" style="font-size: 14px; transition: color 0.2s;" 
                           onclick="navigator.clipboard.writeText('<%= BASE_URL %>/<%= url.shortId %>'); const original = this.className; this.className = 'fa-solid fa-check text-success'; setTimeout(() => this.className = original, 1500)"
                           title="Copy Short URL"></i>
                      </div>
                      <div class="text-secondary small d-flex align-items-center gap-1 mt-1 font-monospace">
                        <span class="text-secondary">↳</span>
                        <span class="text-truncate" style="max-width: 320px;"><%= url.redirectUrl %></span>
                      </div>
                    </div>
                  </div>

                  <!-- Right Side clicks and timestamp stats -->
                  <div class="d-flex align-items-center gap-3">
                    <div class="d-flex flex-column align-items-end">
                      <span class="badge border bg-white text-dark py-2 px-3 fw-semibold d-flex align-items-center gap-2" style="border-radius: 8px; font-size: 13px; border-color: #e2e8f0 !important; color: #475569 !important;">
                        <i class="fa-solid fa-arrow-pointer text-primary" style="color: #0877FD !important; font-size: 11px;"></i>
                        <%= url.visitedHistory.length %> clicks
                      </span>
                      <span class="text-secondary small mt-1" style="font-size: 11px;">Created <%= new Date(url.createdAt).toLocaleDateString() %></span>
                    </div>
                    <!-- Go to URL button -->
                    <a href="<%= BASE_URL %>/<%= url.shortId %>" target="_blank" class="btn btn-outline-primary p-2 d-flex align-items-center justify-content-center" style="border-radius: 8px; border-color: #eaeaea; color: #475569;">
                      <i class="fa-solid fa-arrow-up-right-from-square" style="font-size: 12px;"></i>
                    </a>
                  </div>

                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

      </div>
    </div>
  </div>

  <%- include('partials/script') %>
</body>

</html>