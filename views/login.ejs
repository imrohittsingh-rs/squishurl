<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login Page</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
      }

      body {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #0f172a;
      }

      .container {
        background: #1e293b;
        padding: 30px 40px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        width: 320px;
      }

      h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #f1f5f9;
      }

      .form-group {
        margin-bottom: 15px;
      }

      label {
        font-size: 14px;
        color: #cbd5f5;
        display: block;
        margin-bottom: 5px;
      }

      input {
        width: 100%;
        padding: 10px;
        border: 1px solid #334155;
        border-radius: 6px;
        font-size: 14px;
        outline: none;
        background: #0f172a;
        color: #f1f5f9;
        transition:
          border 0.2s,
          box-shadow 0.2s;
      }

      input:focus {
        border-color: #4da6ff;
        box-shadow: 0 0 5px #4da6ff;
      }

      button {
        width: 100%;
        padding: 10px;
        background: #4da6ff;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
      }

      button:hover {
        background: #3b8de0;
        transform: translateY(-1px);
      }

      .extra {
        margin-top: 15px;
        text-align: center;
        font-size: 14px;
        color: #cbd5f5;
      }

      .extra a {
        color: #4da6ff;
        text-decoration: none;
      }

      .extra a:hover {
        text-decoration: underline;
      }

      .error-msg {
        color: #f87171;
        text-align:center;
        margin-bottom:10px;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h2>Login</h2>

      <% if (error) { %>  
        <p class="error-msg"><%= error %></p>  
      <% } %>

      <form action="/user/login" method="post">
        <div class="form-group">
          <label>Enter your email</label>
          <input type="email" required name="email" placeholder="Enter your email"/>
        </div>

        <div class="form-group">
          <label>Enter your password</label>
          <input type="password" required name="password" placeholder="Enter your password"/>
        </div>

        <button type="submit">Login</button>
      </form>

      <div class="extra">
        Don't have an account? <a href="/signup">Sign Up</a>
      </div>
    </div>
  </body>
</html>
