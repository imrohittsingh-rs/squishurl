<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home Page</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: #f1f5f9;
    }

    h1 {
      text-align: center;
      margin-top: 30px;
      color: #f1f5f9;
    }

    .container {
      width: 90%;
      max-width: 800px;
      margin: 30px auto;
      background: #1e293b;
      padding: 25px 30px;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    }

    form {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }

    input[type="text"] {
      flex: 1;
      padding: 10px;
      border-radius: 6px;
      border: 1px solid #334155;
      outline: none;
      font-size: 14px;
      background: #0f172a;
      color: #f1f5f9;
    }

    input[type="text"]:focus {
      border-color: #4da6ff;
      box-shadow: 0 0 5px #4da6ff;
    }

    button {
      padding: 10px 16px;
      border: none;
      border-radius: 6px;
      background-color: #4da6ff;
      color: white;
      font-weight: 500;
      cursor: pointer;
      transition: 0.2s ease;
    }

    button:hover {
      background-color: #3b8de0;
      transform: translateY(-1px);
    }

    p {
      background: #064e3b;
      padding: 10px;
      border-radius: 6px;
      color: #6ee7b7;
      font-weight: 500;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    thead {
      background-color: #4da6ff;
      color: white;
    }

    th, td {
      padding: 10px;
      text-align: left;
      font-size: 14px;
    }

    tr:nth-child(even) {
      background-color: #0f172a;
    }

    tbody tr:hover {
      background-color: #1e40af33;
    }

    th {
      font-weight: 600;
    }

    td {
      color: #e2e8f0;
    }

    a {
      color: #38bdf8;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    a:hover {
      color: #7dd3fc;
      text-decoration: underline;
    }
  </style>
</head>

<body>
  <h1>URL Shortener</h1>

  <div class="container">

    <% if (locals.id) { %>
      <p>URL Generated: <%= BASE_URL %>/<%= id %></p>
    <% } %>

    <form method="POST" action="/url">
      <input type="text" name="url" placeholder="https://example.com">
      <button type="submit">Generate</button>
    </form>

    <% if (locals.urls) { %>
      <table>
        <thead>
          <tr>
            <th>S. NO.</th>
            <th>ShortId</th>
            <th>Redirect</th>
            <th>link</th>
            <th>Clicks</th>
          </tr>
        </thead>

        <tbody>
          <% urls.forEach((url, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= url.shortId %></td>
              <td><%= url.redirectUrl %></td>
              <td><a href="<%= BASE_URL %>/<%= url.shortId %>" target="_blank"><%= BASE_URL %>/<%= url.shortId %></a></td>
              <td><%= url.visitedHistory.length %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>

  </div>
</body>
</html>
